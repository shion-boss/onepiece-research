# =========================================================================
# Vercel ignore — API project (= Python Functions) のデプロイから除外
# =========================================================================
# API project は repo root を base にして deploy する想定。 web/ など 不要な
# ものを除外して function bundle を軽量化 (= Vercel Python は 500MB 上限)。

# Next.js は別 project にしてあるので不要
web/

# 開発環境
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# テスト / examples (本番 API では呼ばれない)
tests/
examples/

# git / editor
.git/
.gitignore
.vscode/
.idea/

# secret / ローカル env
.env
.env.local
*.log
*.tmp
*.bak

# ローカル開発 only ファイル (= 本番では Postgres に保存される)
db/spectate_comments.sqlite
db/spectate_comments.sqlite-journal
db/spectate_comments.json
db/spectate_comments.json.tmp

# 大規模 replay history (= ローカル走行用、 本番 API には不要)
db/match_replays.sqlite
db/match_replays.sqlite-journal

# =========================================================================
# 学習 / 検証 dev artifact (= 本番 API は spec + cards + overlay の み 必要)
# 2026-05-30 追加: bundle size 爆発 修正 (= db/ 全体 128GB だった)
# =========================================================================

# corpus dump (= self-play game collection、 build_spec 用 = 本番 不 要)
db/game_corpus/

# snapshot dumps (= 教師 label 用、 ローカル 学習 only)
db/snapshots_*
db/self_play_snapshots*
db/twoturn_snapshots*
db/twoturn_snapshots_*
db/snapshots_threeturn*
db/mcts_rollout*
db/online_snapshots*
db/*.jsonl
db/*.jsonl.gz
db/*.iter*

# bonus learning artifact
db/bonus_rounds/
db/spec_backups/
db/target_bonus_history.json
db/target_fire_log.json
db/target_fire_log_errors.ndjson

# AI param backup / experiments
db/ai_params_decks*
db/ai_params*.bak
db/*.bak

# human play log (= Blob で 取 得 + import_human_play_to_spec.py で spec へ。
# 本番 API は spec を 直 参 照 すれば 充 分、 raw log 不 要)
db/human_play_log/

# audit artifact
db/audit_log/
db/audit_inbox/
db/overlay_audit*
db/overlay_when_missing.json
db/cascade_fallback.json

# corpus 派 生 derived data
db/derived/

# その他 大規 模 デー タ
db/cards.sqlite-journal
db/*.tmp
db/*.cache

# 公式 PDF (= ル ー ル 参 照 用、 runtime API は 読 ま な い、 skill 経 由)
db/rules/

# 画像 (= web public で 別 配 信、 API bundle 不 要)
images/

# scraper 中 間 (= 開 発 only)
scraper/

# logs (= 走 行 ログ、 完 全 dev artifact、 166MB)
logs/

# docs (= プロジェクト 文 書、 runtime 不 要)
docs/

# 評 価 結 果 (= eval CLI 出 力、 runtime 不 要)
eval_results/

# Next.js 関 連 (= 別 project)
node_modules/

# scripts (= CLI 開 発 用、 runtime API か ら 呼 ば な い)
scripts/

# 旧 / 退 避 deck (= _archive、 production 配 信 対 象 外)
decks/_archive/

# spec backup / 過 去 round (decks 配 下 にも 場 合 あ り)
decks/_backups/
decks/*.bak

# Claude / agent 設 定 (= 開 発 only)
.claude/
agents/

# pytest / mypy cache (再 列 挙)
.coverage
.coverage.*
htmlcov/
