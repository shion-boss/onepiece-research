# =========================================================================
# プロジェクト固有 (再生成可能 / 大容量 / 著作権配慮)
# =========================================================================

# 画像キャッシュ (~ 1.4 GB) — scraper / scripts で取得
images/
web/public/cards/

# SQLite (cards.json から派生)
db/cards.sqlite
db/cards.sqlite-journal
db/test.sqlite

# 公式PDFテキスト (Bandai 著作物 - scraper で取得)
db/rules/*.pdf
db/rules/*.txt

# 公式 FAQ + cardqa (Bandai 著作物 - scraper で取得)
db/faq/*.json
!db/faq/INDEX.md

# 対戦ログ (ローカル状態)
db/match_history.jsonl

# replay 永続化 (再生成可、 大容量バイナリ)
db/match_replays.sqlite
db/match_replays.sqlite-journal

# 研究セッション (Phase R)
db/research_sessions.sqlite
db/research_sessions.sqlite-journal
db/research_sessions.sqlite-wal
db/research_sessions.sqlite-shm

# matchup_matrix の一時バックアップ (= 適用前の snapshot)
db/matchup_matrix.before.json

# Phase 2 (= outcome regression 学習) 関連の一時/再生成可能ファイル
db/self_play_snapshots*.jsonl
db/self_play_snapshots*.log
db/ai_params.suggested.json
db/ai_params.*.bak.json
db/ai_params.pre_phase2.json
db/matchup_matrix.pre_phase2.json

# matrix 走行ログ (= UI preview 用 NDJSON、 再生成可)
db/matrix_run_log.ndjson

# spectate コメント (= ローカル開発用 SQLite + 旧 JSON)。 本番は Vercel/Neon Postgres。
db/spectate_comments.sqlite
db/spectate_comments.sqlite-journal
db/spectate_comments.sqlite-wal
db/spectate_comments.sqlite-shm
db/spectate_comments.json
db/spectate_comments.json.tmp

# overlay 候補 (生成物、必要に応じて再生成)
db/card_effects.suggestions.json

# scraper のハッシュキャッシュ (再生成可)
db/.update_cache.json

# 旧 scrape_meta_decks.py の出力 (cardrush スクリプトに置き換え済)
db/meta_decks/

# デッキ退避ディレクトリ (cardrush 履歴)
decks/_archive/

# 探索エンジン (Phase B) の生成候補デッキ
decks/_candidates/

# 研究 artifact (Phase R = 対策デッキ研究ラボ / 改善ワークフロー の output)
# API 経由で生成される一過性ファイル、 ローカル保管のみ
decks/explore_*.json
decks/research_*.json

# 一時ファイル
/tmp/
*.log

# =========================================================================
# Claude Code 個別設定 (チームで共有しない)
# =========================================================================
.claude/settings.local.json
.claude/cache/
.claude/scheduled_tasks.lock
.claude/*.log

# Node modules (ルート直下に万が一できた場合)
node_modules/
